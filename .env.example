# =====================================================================
# Variáveis de ambiente — MODELO (template)
# Copie este arquivo para ".env.local" e preencha com as chaves reais
# do seu projeto Supabase. NUNCA coloque chaves reais aqui no .example.
#
# Onde achar cada chave: veja o arquivo SETUP_SUPABASE.md (passo a passo).
# =====================================================================

# URL do projeto Supabase (ex.: https://abcdxyz.supabase.co)  — SEM "/rest/v1" no final
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (pode aparecer no navegador, é segura para o client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave secreta "service_role" — SOMENTE NO SERVIDOR. NUNCA expor no client!
SUPABASE_SERVICE_ROLE_KEY=

